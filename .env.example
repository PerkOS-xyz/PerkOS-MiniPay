# ─── Celo / MiniPay ───────────────────────────────────────────────────────────
# Celo mainnet RPC (defaults to Forno when unset). Alchemy also supports Celo.
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo.org
# Platform/escrow address that receives cUSD pay-as-you-go payments.
NEXT_PUBLIC_PAYMENT_ADDRESS=

# ─── PerkOS backend (agent / team / PM-dispatcher API) ────────────────────────
NEXT_PUBLIC_PERKOS_API_URL=https://api.perkos.xyz
# Default public runtime image tag used when launching the starter team (ECS).
# Leave blank to create agents without ECS provisioning. Get a public tag from PerkOS-Admin → runtimes.
NEXT_PUBLIC_PERKOS_DEFAULT_IMAGE_TAG=

# ─── Firebase (client) — SAME project as the PerkOS mini-app (copy from PerkOS/.env) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin (server) — service account, same as PerkOS-API (copy from PerkOS/.env) ──
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Access gate ──────────────────────────────────────────────────────────────
# MiniPay launches public. Set true to allow any wallet to sign in (skips the alpha allowlist).
PERKOS_PUBLIC_MODE=false
# Or a comma-separated allowlist for testing.
PERKOS_WHITELIST=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://minipay.perkos.xyz

# Dynamic.xyz browser wallet (regular-browser host only; MiniPay never mounts it).
# Use the SAME environment id as the main PerkOS App (copy from PerkOS/.env).
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=
