# --- Celo / MiniPay ---
# Celo mainnet RPC (defaults to Forno when unset). Alchemy also supports Celo.
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo.org

# Platform/escrow address that receives cUSD pay-as-you-go payments.
NEXT_PUBLIC_PAYMENT_ADDRESS=

# --- PerkOS backend (agent / team / PM-dispatcher API) ---
NEXT_PUBLIC_PERKOS_API_URL=https://api.perkos.xyz

# --- App ---
NEXT_PUBLIC_SITE_URL=https://minipay.perkos.xyz
